# WebAgent (Rust) — example environment configuration.
# Copy to `.env` and adjust. `.env` is gitignored; never commit real values.

# --- Browser / CDP ---
# Attach to an existing Chrome DevTools Protocol endpoint instead of launching one.
# WEBAGENT_CDP_ENDPOINT=http://127.0.0.1:9222

# Path to the Chrome/Chromium executable to launch.
# WEBAGENT_CHROME=C:\Program Files\Google\Chrome\Application\chrome.exe

# Base port for per-instance CDP debug ports.
# WEBAGENT_DEBUG_PORT_BASE=9222

# Directory for browser profiles.
# WEBAGENT_PROFILE_DIR=./profiles

# Reuse a single shared browser instance (1/true to enable).
# WEBAGENT_SHARED_BROWSER=0

# --- Tuning ---
# Multiplier applied to internal timeouts (float).
# WEBAGENT_TIMEOUT_MULT=1.0

# Lower/upper clamps for computed timeouts (milliseconds).
# WEBAGENT_TIMEOUT_MIN=1000
# WEBAGENT_TIMEOUT_MAX=60000
