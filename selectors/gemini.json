{
  "composer": [
    "rich-textarea > div > p",
    "rich-textarea div[contenteditable='true']",
    "div[contenteditable='true']",
    "textarea",
    "div[role='textbox']"
  ],
  "send_button": [
    "div[class*='send-button-container'] > button",
    "button[aria-label*='Send' i]",
    "button[aria-label*='Nachricht senden' i]",
    "button[type='submit']"
  ],
  "consent_reject_button": [
    "button:has-text('Alle ablehnen')",
    "button:has-text('Reject all')"
  ],
  "notice_close_button": [
    "button:has-text('Schließen')",
    "button:has-text('Close')"
  ],
  "response_preference_prompt": [
    "text=/Welche Antwort (bevorzugst|gefällt dir besser)/i",
    "text=/Für welche Antwort entscheidest du dich/i",
    "text=/Which response do you prefer/i",
    "text=/Which response is better/i"
  ],
  "response_preference_choice": [
    "button[aria-label*='Antwort 1' i]",
    "button[aria-label*='Response 1' i]",
    "button[aria-label*='Antwort A' i]",
    "button[aria-label*='Response A' i]",
    "button:has-text('Antwort 1')",
    "button:has-text('Response 1')",
    "button:has-text('Antwort A')",
    "button:has-text('Response A')",
    "button:has-text('Diese Antwort')",
    "button:has-text('This response')"
  ],
  "stop_button": [
    "button[aria-label*='Stop' i]",
    "button[aria-label*='stop' i]",
    "button:has-text('Stop')",
    "button[aria-label*='Stop generating']"
  ],
  "assistant_message": [
    "message-content[class*='model-response-text']",
    "div[class*='model-response-text']",
    "div[class*='response-text']",
    "div.prose",
    "div[class*='markdown']",
    "div[class*='message-content']",
    "div[class*='response']"
  ],
  "new_chat_button": [
    "button[aria-label*='New chat' i]",
    "button[aria-label*='Start new chat']",
    "a[href='/']",
    "button:has-text('New chat')",
    "button:has-text('Neuer Chat')"
  ],
  "login_button": [
    "text=Sign in",
    "text=Log in",
    "text=Anmelden",
    "button:has-text('Sign in')",
    "button:has-text('Log in')",
    "button:has-text('Anmelden')",
    "a:has-text('Anmelden')"
  ],
  "login_indicator": [
    "rich-textarea > div > p",
    "rich-textarea div[contenteditable='true']",
    "div[contenteditable='true']"
  ]
}
