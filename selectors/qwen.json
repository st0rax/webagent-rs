{
  "composer": [
    "textarea.message-input-textarea",
    "textarea",
    "div[contenteditable='true']"
  ],
  "send_button": [
    "button[aria-label*='Send' i]",
    "button[type='submit']"
  ],
  "consent_reject_button": [
    "button:has-text('Alle unbedingt erforderlichen Cookies akzeptieren')",
    "button:has-text('Accept only necessary cookies')",
    "button:has-text('Only necessary')"
  ],
  "stop_button": [
    "button[aria-label*='Stop']",
    "button[aria-label*='stop']",
    "button:has-text('Stop')",
    "button[aria-label*='Stop generating']"
  ],
  "assistant_message": [
    "div.qwen-chat-message-assistant div.response-message-content.phase-answer",
    "div.qwen-chat-message-assistant div.custom-qwen-markdown"
  ],
  "new_chat_button": [
    "button[aria-label*='New chat' i]",
    "a[href='/']",
    "button:has-text('New chat')",
    "button:has-text('Neuer Chat')"
  ],
  "login_button": [
    "text=Log in",
    "button:has-text('Log in')",
    "text=Sign up",
    "button:has-text('Sign up')"
  ],
  "login_indicator": [
    "textarea.message-input-textarea",
    "textarea",
    "div[contenteditable='true']"
  ]
}
